---
interface Props {
  source: string;
  title: string;
  tags: string[];
}

const { source, title, tags } = Astro.props;
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title={`${title} — Junior Hou`}>
  <Nav />
  <main class="story-main">
    <div class="story-inner">
      <a href="/about-me" class="back-link">&larr; Back to profile</a>
      <p class="story-source">{source}</p>
      <h1 class="story-title">{title}</h1>
      <div class="story-tags">
        {tags.map((tag) => <span class="story-tag">#{tag}</span>)}
      </div>
      <div class="story-body">
        <slot />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .story-main {
    padding: 4rem var(--pad-x) 6rem;
  }

  .story-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    transition: color 0.12s ease;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .story-source {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .story-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .story-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 0.75rem;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .story-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .story-body {
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
    color: var(--text-soft);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .story-body :global(h2) {
    font-size: 1.375rem;
    color: var(--text-primary);
    margin-top: 0.5rem;
  }

  .story-body :global(ul) {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .story-body :global(li) {
    color: var(--text-soft);
  }

  .story-body :global(.result-highlight) {
    background: var(--bg-warm);
    border-left: 2.5px solid var(--accent);
    padding: 1.5rem 2rem;
    margin: 0.5rem 0;
  }

  .story-body :global(.image-placeholder) {
    background: var(--bg-warm);
    border: 1px solid var(--border);
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.875rem;
  }
</style>
