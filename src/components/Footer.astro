<footer class="footer">
  <div class="footer-inner">
    <span class="footer-left">Junior Hou &middot; 2026</span>
  </div>
</footer>

<style>
  .footer {
    padding: 1.75rem var(--pad-x);
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-left {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 0.12s ease;
  }

  .footer-links a:hover {
    color: var(--text-primary);
  }
</style>
