---
const nodes = [
  { label: 'Discover', sub: 'Market & consumer insight' },
  { label: 'Position', sub: 'Messaging & brand strategy' },
  { label: 'Execute', sub: 'Campaign & GTM delivery' },
  { label: 'Manage', sub: 'Teams & agencies' },
  { label: 'Measure', sub: 'Track & optimize results' },
];
---

<section class="capabilities">
  <div class="capabilities-inner">
    <p class="section-label">What I bring to the table</p>
    <div class="flow">
      {
        nodes.map((node, i) => (
          <>
            <div class="node">
              <span class="node-label">{node.label}</span>
              <span class="node-sub">{node.sub}</span>
            </div>
            {i < nodes.length - 1 && (
              <div class="arrow" aria-hidden="true">
                <svg width="28" height="16" viewBox="0 0 28 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 8H24" stroke="#B87333" stroke-width="1.5"/>
                  <path d="M19 2L26 8L19 14" stroke="#B87333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </>
        ))
      }
    </div>
  </div>
</section>

<style>
  .capabilities {
    background: var(--bg-warm);
    padding: 4rem var(--pad-x);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .capabilities-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .flow {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: 2rem;
  }

  .node {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .node-label {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .node-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .arrow {
    display: flex;
    align-items: center;
    padding: 0 1.25rem;
    flex-shrink: 0;
    padding-bottom: 1.25rem;
  }

  @media (max-width: 900px) {
    .flow {
      display: grid;
      grid-template-columns: repeat(3, auto);
      justify-content: start;
    }

    .arrow:nth-of-type(4) {
      display: none;
    }
  }
</style>
